[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/ui/level_complete.gd" id="1_lvl"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_panel"]
bg_color = Color(0.08, 0.10, 0.18, 0.96)
set_border_width_all = 3
border_color = Color(1, 0.85, 0.32, 1)
set_corner_radius_all = 12

[node name="LevelComplete" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_lvl")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.03, 0.04, 0.08, 1)

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Panel" type="PanelContainer" parent="Center"]
layout_mode = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_panel")

[node name="Margin" type="MarginContainer" parent="Center/Panel"]
theme_override_constants/margin_left = 48
theme_override_constants/margin_top = 36
theme_override_constants/margin_right = 48
theme_override_constants/margin_bottom = 36

[node name="VBox" type="VBoxContainer" parent="Center/Panel/Margin"]
alignment = 1
theme_override_constants/separation = 22

[node name="Title" type="Label" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
text = "FINISHED LEVEL"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 48
theme_override_colors/font_color = Color(1, 0.85, 0.32, 1)

[node name="Subtitle" type="Label" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
text = "You survived 5 minutes."
horizontal_alignment = 1
theme_override_font_sizes/font_size = 22
theme_override_colors/font_color = Color(0.85, 0.88, 0.96, 1)

[node name="Stats" type="VBoxContainer" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 6

[node name="TimeLabel" type="Label" parent="Center/Panel/Margin/VBox/Stats"]
layout_mode = 2
text = "Time: 0:00"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 22

[node name="KillsLabel" type="Label" parent="Center/Panel/Margin/VBox/Stats"]
layout_mode = 2
text = "Kills: 0"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 22

[node name="LevelLabel" type="Label" parent="Center/Panel/Margin/VBox/Stats"]
layout_mode = 2
text = "Level: 1"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 22

[node name="GoldLabel" type="Label" parent="Center/Panel/Margin/VBox/Stats"]
layout_mode = 2
text = "Total gold: 0"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 22
theme_override_colors/font_color = Color(1, 0.85, 0.32, 1)

[node name="MainMenuButton" type="Button" parent="Center/Panel/Margin/VBox"]
custom_minimum_size = Vector2(320, 72)
layout_mode = 2
size_flags_horizontal = 4
text = "Return to Menu"
theme_override_font_sizes/font_size = 28

[connection signal="pressed" from="Center/Panel/Margin/VBox/MainMenuButton" to="." method="_on_main_menu_button_pressed"]
